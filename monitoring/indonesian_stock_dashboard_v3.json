{
  "title": "Indonesian Stock Prediction Dashboard",
  "uid": "indonesian-stock-mlops-v3",
  "timezone": "Asia/Jakarta",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "5m",
  "templating": {
    "list": [
      {
        "name": "ticker",
        "label": "Ticker",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(stock_predictions_total, ticker)",
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {},
        "refresh": 2,
        "sort": 1,
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Total Predictions",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          },
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(stock_predictions_total{ticker=~\"$ticker\"})",
          "legendFormat": "Total",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "id": 2,
      "title": "🟢 BUY Signals",
