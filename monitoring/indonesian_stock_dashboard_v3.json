        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "red",
            "mode": "fixed"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(stock_predictions_total{signal=\"SELL\", ticker=~\"$ticker\"})",
          "legendFormat": "SELL",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "id": 4,
      "title": "BUY / SELL Ratio",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.8
              },
              {
                "color": "green",
                "value": 1.2
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(stock_predictions_total{signal=\"BUY\", ticker=~\"$ticker\"}) / sum(stock_predictions_total{signal=\"SELL\", ticker=~\"$ticker\"})",
          "legendFormat": "Ratio",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "id": 5,
      "title": "Avg Confidence",
      "type": "stat",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 0.65
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "targets": [
        {
          "expr": "avg(prediction_confidence_sum{ticker=~\"$ticker\"} / prediction_confidence_count{ticker=~\"$ticker\"})",
          "legendFormat": "Avg",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "id": 6,
      "title": "Tickers Tracked",
      "type": "stat",
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "purple",
            "mode": "fixed"
          },
          "thresholds": {
            "steps": [
              {
                "color": "purple",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count(sum by (ticker) (stock_predictions_total{ticker=~\"$ticker\"}))",
          "legendFormat": "Tickers",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "id": 10,
      "title": "📊 Confidence Overview",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 7,
      "title": "Model Confidence per Ticker",
      "type": "bargauge",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 10
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "minVizWidth": 10,
        "minVizHeight": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 0.65
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sort_desc(prediction_confidence_sum{ticker=~\"$ticker\"} / prediction_confidence_count{ticker=~\"$ticker\"})",
          "legendFormat": "{{ticker}}",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "id": 11,
      "title": "📋 Signal Tables",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 8,
      "title": "🟢 BUY Signals — Sorted by Confidence",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 10
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Confidence",
            "desc": true
          }
        ],
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Confidence"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percentunit"
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "yellow",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": 0.65
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Signal"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "BUY": {
                        "color": "green",
                        "text": "🟢 BUY"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "filterByValue",
          "options": {
            "filters": [
              {
                "fieldName": "signal",
                "config": {
                  "id": "equal",
                  "options": {
                    "value": "BUY"
                  }
                }
              }
            ],
            "type": "include",
            "match": "any"
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "ticker": "Ticker",
              "Value #A": "Confidence",
              "signal": "Signal"
            },
            "excludeByName": {
              "Time": true,
              "Value #B": true
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "prediction_confidence_sum{ticker=~\"$ticker\"} / prediction_confidence_count{ticker=~\"$ticker\"}",
          "legendFormat": "{{ticker}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "sum by (ticker, signal) (stock_predictions_total{signal=\"BUY\", ticker=~\"$ticker\"}) > 0",
          "legendFormat": "{{ticker}}",
          "refId": "B",
          "instant": true,
          "format": "table"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
